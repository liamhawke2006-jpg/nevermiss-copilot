# Copilot engine. Leave OFFLINE=1 to run/demo/test with no keys.
COPILOT_OFFLINE=1
COPILOT_WORKSPACE=workspace
COPILOT_PORT=3300
COPILOT_AUTONOMY=auto-safe-hold-world

# The brain (live Claude tool-use agent). Also: npm i @anthropic-ai/sdk
ANTHROPIC_API_KEY=
COPILOT_MODEL=claude-sonnet-4-6

# First real DOER — email via SendGrid (API key only, no OAuth).
# With this set + OFFLINE=0, an approved "Send email" actually sends.
SENDGRID_API_KEY=
MAIL_FROM=copilot@yourbusiness.com

# Encrypts each tenant's secrets at rest (AES-256-GCM). REQUIRED in production.
COPILOT_SECRET_KEY=

# Gmail "Connect" (OAuth). Register the redirect below in Google Cloud console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://copilot.yourdomain.com

# Platform (Railway/Render) sets PORT automatically; COPILOT_PORT is the local default.
# PORT=

# Capability kill switches (all default on):
# CAP_FILES CAP_SHELL CAP_HTTP CAP_COMMS CAP_BROWSER CAP_DESKTOP
